# Aegis controller — example environment file.
#
# Every variable below has a built-in default that targets the local
# docker-compose dev stack. Copy to .env and edit only what you need
# to change.

# HTTP listen address. Use 127.0.0.1:PORT to bind loopback only.
AEGIS_HTTP_ADDR=:8080

# Source of truth. Points at the docker-compose Postgres service by
# default; the host-mapped 5432 makes this work for `go run` on the host too.
AEGIS_DATABASE_URL=postgres://aegis:aegis@localhost:5432/aegis?sslmode=disable

# Cache + pubsub. Not yet connected by the controller (lands in 0.5+).
AEGIS_REDIS_URL=redis://localhost:6379/0

# Logging: level = debug|info|warn|error  ·  format = json|text
AEGIS_LOG_LEVEL=info
AEGIS_LOG_FORMAT=json

# Graceful shutdown deadline once SIGTERM/SIGINT arrives.
AEGIS_SHUTDOWN_TIMEOUT=30s

# Set to true to bypass goose migrations on startup (rare; operator-managed).
AEGIS_SKIP_MIGRATIONS=false

# ----------------------------------------------------------------------
# Auth
# ----------------------------------------------------------------------

# REQUIRED. HS256 signing key for access JWTs. No default by design —
# the controller refuses to start without it. Generate with:
#   openssl rand -hex 48
# Minimum length: 32 characters.
#
# CHANGE-ME-development-only-not-for-production-use-XXXXXXXXXXXXX
AEGIS_JWT_SECRET=CHANGE-ME-development-only-not-for-production-use

# Access JWT lifetime. Short-lived; client refreshes from the panel.
AEGIS_ACCESS_TOKEN_TTL=15m

# Refresh-token (server-side session) lifetime. Rotates on every use.
AEGIS_REFRESH_TOKEN_TTL=720h

# First-boot god user. Set BOTH to provision the initial superuser on
# fresh databases; remove (or leave empty) after the user exists. The
# bootstrap is a no-op when any god user already exists.
AEGIS_BOOTSTRAP_EMAIL=
AEGIS_BOOTSTRAP_PASSWORD=

# ----------------------------------------------------------------------
# Agent endpoint (mTLS + WSS)
# ----------------------------------------------------------------------

# Separate port from the browser/API endpoint — distinct TLS configs.
# Agents dial wss://<host>:8443/agent/v1/ws.
AEGIS_AGENT_ADDR=:8443

# Where the internal CA's material lives. Created on first boot.
# Back this directory up — losing it means re-issuing every agent cert.
AEGIS_CA_DIR=/var/lib/aegis/ca

# The hostname agents will connect to; baked into the controller's TLS
# server cert as CN/SAN. localhost is fine for single-host dev.
AEGIS_AGENT_SERVER_NAME=localhost

# Overall deadline per Add-Server job. Includes SSH connect, file
# uploads, systemd start, and the wait for the agent to dial home.
AEGIS_PROVISION_TIMEOUT=10m

# Optional: the WSS URL the provisioned agent should dial. Leave empty
# to auto-derive from AGENT_SERVER_NAME + AGENT_ADDR.
# AEGIS_AGENT_PUBLIC_URL=wss://aegis.example.com:8443/agent/v1/ws
